{% comment %}
  Education renderer — đồng bộ layout với experience timeline
{% endcomment %}

<div class="cv-edu-list">
  {% for entry in entries %}
    {% assign start_raw = entry.start_date | default: entry.startDate | strip %}
    {% assign end_raw   = entry.end_date   | default: entry.endDate   | strip %}

    {% assign start_parts = start_raw | split: '-' %}
    {% assign start_year  = start_parts[0] %}
    {% assign end_parts   = end_raw | split: '-' %}
    {% assign end_year    = end_parts[0] %}

    <div class="cv-edu-entry">
      <!-- Date column -->
      <div class="cv-edu-dates">
        {% if start_year and end_year %}
          <span class="cv-edu-period">{{ start_year }} – {{ end_year }}</span>
        {% elsif start_year %}
          <span class="cv-edu-period">{{ start_year }}</span>
        {% endif %}
      </div>

      <!-- Spine -->
      <div class="cv-tl-spine">
        <div class="tl-dot"></div>
        <div class="tl-line"></div>
      </div>

      <!-- Card -->
      <div class="cv-exp-card">
        {% capture study_type %}{% if entry.studyType %}{{ entry.studyType }}{% elsif entry.degree %}{{ entry.degree }}{% endif %}{% endcapture %}
        {% if study_type != '' %}
          <span class="cv-exp-position">
            {% if entry.url %}<a href="{{ entry.url }}" target="_blank">{{ study_type }}</a>{% else %}{{ study_type }}{% endif %}
          </span>
        {% endif %}
        <div class="cv-exp-company">
          {{ entry.institution }}
          {% if entry.location %}
            <span class="sep">&middot;</span>
            <span class="cv-exp-location">{{ entry.location }}</span>
          {% endif %}
        </div>
        {% if entry.area %}
          <p style="font-size:0.8rem;color:var(--global-text-color-light);margin:0 0 0.35rem;font-style:italic;">{{ entry.area }}</p>
        {% endif %}
        {% if entry.courses or entry.highlights %}
          <ul class="cv-exp-highlights">
            {% for item in entry.courses %}
              <li>{{ item }}</li>
            {% endfor %}
            {% for item in entry.highlights %}
              <li>{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>
  {% endfor %}
</div>

<style>
.cv-edu-list {
  display: flex;
  flex-direction: column;
}
.cv-edu-entry {
  display: grid;
  grid-template-columns: 62px 18px 1fr;
  gap: 0 0.6rem;
}
.cv-edu-dates {
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  padding-top: 0.45rem;
}
.cv-edu-period {
  font-size: 0.62rem;
  font-weight: 700;
  color: var(--global-theme-color);
  white-space: nowrap;
  line-height: 1;
}

/* ── Mobile: collapse to 1 column, date inline ───────────────── */
@media (max-width: 600px) {
  .cv-edu-entry {
    grid-template-columns: 1fr;
    gap: 0;
  }
  .cv-edu-dates {
    justify-content: flex-start;
    padding: 0.5rem 0 0.15rem;
  }
  .cv-edu-period { font-size: 0.68rem; }
  .cv-edu-entry .cv-tl-spine { display: none; }
  .cv-edu-entry .cv-exp-card { margin: 0.15rem 0 1rem; }
}
</style>
